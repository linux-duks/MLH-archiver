['---\n'
 ' common/fuzzy    |    6 ++++-\n'
 ' common/populate |   12 ++++++++--\n'
 ' common/xfs      |   65 '
 '+++++++++++++++++++++++++++++++++++++++++++++++--------\n'
 ' 3 files changed, 71 insertions(+), 12 deletions(-)\n'
 '\n'
 '\n'
 'diff --git a/common/fuzzy b/common/fuzzy\n'
 'index b72ee3f67f..d504f0854e 100644\n'
 '--- a/common/fuzzy\n'
 '+++ b/common/fuzzy\n'
 '@@ -309,7 +309,11 @@ __scratch_xfs_fuzz_mdrestore()\n'
 ' \t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_LOGDEV" ] && \\\n'
 ' \t\tlogdev=$SCRATCH_LOGDEV\n'
 ' \n'
 '-\t_xfs_mdrestore "${POPULATE_METADUMP}" "${SCRATCH_DEV}" "${logdev}" || \\\n'
 '+\tlocal rtdev=none\n'
 '+\t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_RTDEV" ] && \\\n'
 '+\t\trtdev=$SCRATCH_RTDEV\n'
 '+\n'
 '+\t_xfs_mdrestore "${POPULATE_METADUMP}" "${SCRATCH_DEV}" "${logdev}" '
 '"${rtdev}" || \\\n'
 ' \t\t_fail "${POPULATE_METADUMP}: Could not find metadump to restore?"\n'
 ' }\n'
 ' \n'
 'diff --git a/common/populate b/common/populate\n'
 'index 450b024bfc..dc89eee70e 100644\n'
 '--- a/common/populate\n'
 '+++ b/common/populate\n'
 '@@ -1017,7 +1017,11 @@ _scratch_populate_restore_cached() {\n'
 ' \n'
 ' \tcase "${FSTYP}" in\n'
 ' \t"xfs")\n'
 '-\t\t_xfs_mdrestore "${metadump}" "${SCRATCH_DEV}" "${logdev}"\n'
 '+\t\tlocal rtdev=none\n'
 '+\t\t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_RTDEV" ] && \\\n'
 '+\t\t\trtdev=$SCRATCH_RTDEV\n'
 '+\n'
 '+\t\t_xfs_mdrestore "${metadump}" "${SCRATCH_DEV}" "${logdev}" "${rtdev}"\n'
 ' \t\treturn $?\n'
 ' \t\t;;\n'
 ' \t"ext2"|"ext3"|"ext4")\n'
 '@@ -1039,8 +1043,12 @@ _scratch_populate_save_metadump()\n'
 ' \t\t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_LOGDEV" ] && \\\n'
 ' \t\t\tlogdev=$SCRATCH_LOGDEV\n'
 ' \n'
 '+\t\tlocal rtdev=none\n'
 '+\t\t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_RTDEV" ] && \\\n'
 '+\t\t\trtdev=$SCRATCH_RTDEV\n'
 '+\n'
 ' \t\t_xfs_metadump "$metadump_file" "$SCRATCH_DEV" "$logdev" \\\n'
 '-\t\t\t\tcompress\n'
 '+\t\t\t\t"$rtdev" compress\n'
 ' \t\tres=$?\n'
 ' \t\t;;\n'
 ' \t"ext2"|"ext3"|"ext4")\n'
 'diff --git a/common/xfs b/common/xfs\n'
 'index 1136d685e7..1ff81f4cc2 100644\n'
 '--- a/common/xfs\n'
 '+++ b/common/xfs\n'
 '@@ -681,11 +681,17 @@ _xfs_metadump() {\n'
 ' \tlocal metadump="$1"\n'
 ' \tlocal device="$2"\n'
 ' \tlocal logdev="$3"\n'
 '-\tlocal compressopt="$4"\n'
 '-\tshift; shift; shift; shift\n'
 '+\tlocal rtdev="$4"\n'
 '+\tlocal compressopt="$5"\n'
 '+\tshift; shift; shift; shift; shift\n'
 ' \tlocal options="$@"\n'
 ' \ttest -z "$options" && options="-a -o"\n'
 ' \tlocal metadump_has_dash_x\n'
 '+\tlocal metadump_has_dash_r\n'
 '+\n'
 '+\t# Does metadump support capturing realtime devices?\n'
 "+\t$XFS_METADUMP_PROG --help 2>&1 | grep -q -- '-r rtdev' && \\\n"
 '+\t\t\tmetadump_has_dash_r=1\n'
 ' \n'
 ' \t# Use metadump v2 format unless the user gave us a specific version\n'
 " \t$XFS_METADUMP_PROG --help 2>&1 | grep -q -- '-v version' && \\\n"
 '@@ -699,6 +705,10 @@ _xfs_metadump() {\n'
 ' \t\toptions="$options -l $logdev"\n'
 ' \tfi\n'
 ' \n'
 '+\tif [ "$rtdev" != "none" ] && [ -n "$metadump_has_dash_r" ]; then\n'
 '+\t\toptions="$options -r $rtdev"\n'
 '+\tfi\n'
 '+\n'
 ' \t$XFS_METADUMP_PROG $options "$device" "$metadump"\n'
 ' \tres=$?\n'
 ' \t[ "$compressopt" = "compress" ] && [ -n "$DUMP_COMPRESSOR" ] &&\n'
 '@@ -710,14 +720,19 @@ _xfs_mdrestore() {\n'
 ' \tlocal metadump="$1"\n'
 ' \tlocal device="$2"\n'
 ' \tlocal logdev="$3"\n'
 '-\tshift; shift; shift\n'
 '+\tlocal rtdev="$4"\n'
 '+\tshift; shift; shift; shift\n'
 ' \tlocal options="$@"\n'
 ' \tlocal need_repair\n'
 ' \tlocal mdrestore_has_dash_l\n'
 '+\tlocal mdrestore_has_dash_r\n'
 ' \n'
 ' \t# Does mdrestore support restoring to external devices?\n'
 " \t$XFS_MDRESTORE_PROG --help 2>&1 | grep -q -- '-l logdev' &&\n"
 ' \t\t\tmdrestore_has_dash_l=1\n'
 '+\t# Does mdrestore support restoring to realtime devices?\n'
 "+\t$XFS_MDRESTORE_PROG --help 2>&1 | grep -q -- '-r rtdev' &&\n"
 '+\t\t\tmdrestore_has_dash_r=1\n'
 ' \n'
 " \t# If we're configured for compressed dumps and there isn't already an\n"
 ' \t# uncompressed dump, see if we can use DUMP_COMPRESSOR to decompress\n'
 '@@ -743,6 +758,20 @@ _xfs_mdrestore() {\n'
 ' \t\t$XFS_IO_PROG -d -c \'pwrite -S 0 -q 0 1m\' "$logdev"\n'
 ' \tfi\n'
 ' \n'
 '+\tif [ "$rtdev" != "none" ]; then\n'
 '+\t\t# We have a realtime device.  If mdrestore supports restoring\n'
 '+\t\t# to it, configure ourselves to do that.\n'
 '+\t\tif [ -n "$mdrestore_has_dash_r" ]; then\n'
 '+\t\t\toptions="$options -r $rtdev"\n'
 '+\t\tfi\n'
 '+\n'
 "+\t\t# Wipe the realtime device.  If mdrestore doesn't support\n"
 "+\t\t# restoring to realtime devices or the metadump file doesn't\n"
 '+\t\t# capture the realtime group headers, this is our only chance\n'
 '+\t\t# to signal that the log header needs to be rewritten.\n'
 '+\t\t$XFS_IO_PROG -d -c \'pwrite -S 0 -q 0 1m\' "$rtdev"\n'
 '+\tfi\n'
 '+\n'
 ' \t$XFS_MDRESTORE_PROG $options "${metadump}" "${device}"\n'
 ' \tres=$?\n'
 ' \ttest $res -ne 0 && return $res\n'
 '@@ -757,6 +786,16 @@ _xfs_mdrestore() {\n'
 ' \t\tfi\n'
 ' \tfi\n'
 ' \n'
 "+\t# If there's a realtime device, check to see if the restore rewrote the\n"
 '+\t# rt group headers.  If not, we need to run xfs_repair to format new\n'
 '+\t# group headers onto the realtime device.\n'
 '+\tif [ "$rtdev" != "none" ] && [ -z "$need_repair" ]; then\n'
 '+\t\tmagic="$($XFS_IO_PROG -c \'pread -q -v 0 4\' "$rtdev")"\n'
 '+\t\tif [ "$magic" = "00000000:  00 00 00 00  ...." ]; then\n'
 '+\t\t\tneed_repair=1\n'
 '+\t\tfi\n'
 '+\tfi\n'
 '+\n'
 ' \ttest -z "$need_repair" && return 0\n'
 ' \n'
 ' \techo "repairing fs to fix uncaptured parts of fs." >> $seqres.full\n'
 '@@ -768,12 +807,16 @@ _scratch_xfs_metadump()\n'
 ' {\n'
 ' \tlocal metadump=$1\n'
 ' \tshift\n'
 '+\n'
 ' \tlocal logdev=none\n'
 '-\n'
 ' \t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_LOGDEV" ] && \\\n'
 ' \t\tlogdev=$SCRATCH_LOGDEV\n'
 ' \n'
 '-\t_xfs_metadump "$metadump" "$SCRATCH_DEV" "$logdev" nocompress "$@"\n'
 '+\tlocal rtdev=none\n'
 '+\t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_RTDEV" ] && \\\n'
 '+\t\trtdev=$SCRATCH_RTDEV\n'
 '+\n'
 '+\t_xfs_metadump "$metadump" "$SCRATCH_DEV" "$logdev" "$rtdev" nocompress '
 '"$@"\n'
 ' }\n'
 ' \n'
 ' # Restore snapshotted metadata on the scratch device\n'
 '@@ -786,7 +829,11 @@ _scratch_xfs_mdrestore()\n'
 ' \t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_LOGDEV" ] && \\\n'
 ' \t\tlogdev=$SCRATCH_LOGDEV\n'
 ' \n'
 '-\t_xfs_mdrestore "$metadump" "$SCRATCH_DEV" "$logdev" "$@"\n'
 '+\tlocal rtdev=none\n'
 '+\t[ "$USE_EXTERNAL" = yes -a ! -z "$SCRATCH_RTDEV" ] && \\\n'
 '+\t\trtdev=$SCRATCH_RTDEV\n'
 '+\n'
 '+\t_xfs_mdrestore "$metadump" "$SCRATCH_DEV" "$logdev" "$rtdev" "$@"\n'
 ' }\n'
 ' \n'
 ' # Do not use xfs_repair (offline fsck) to rebuild the filesystem\n'
 '@@ -923,7 +970,7 @@ _check_xfs_filesystem()\n'
 ' \tif [ "$ok" -ne 1 ] && [ "$DUMP_CORRUPT_FS" = "1" ]; then\n'
 ' \t\tlocal flatdev="$(basename "$device")"\n'
 ' \t\t_xfs_metadump "$seqres.$flatdev.check.md" "$device" "$logdev" \\\n'
 '-\t\t\tcompress >> $seqres.full\n'
 '+\t\t\t"$rtdev" compress >> $seqres.full\n'
 ' \tfi\n'
 ' \n'
 ' \t# Optionally test the index rebuilding behavior.\n'
 '@@ -956,7 +1003,7 @@ _check_xfs_filesystem()\n'
 ' \t\tif [ "$rebuild_ok" -ne 1 ] && [ "$DUMP_CORRUPT_FS" = "1" ]; then\n'
 ' \t\t\tlocal flatdev="$(basename "$device")"\n'
 ' \t\t\t_xfs_metadump "$seqres.$flatdev.rebuild.md" "$device" \\\n'
 '-\t\t\t\t"$logdev" compress >> $seqres.full\n'
 '+\t\t\t\t"$logdev" "$rtdev" compress >> $seqres.full\n'
 ' \t\tfi\n'
 ' \tfi\n'
 ' \n'
 '@@ -1040,7 +1087,7 @@ _check_xfs_filesystem()\n'
 ' \t\tif [ "$orebuild_ok" -ne 1 ] && [ "$DUMP_CORRUPT_FS" = "1" ]; then\n'
 ' \t\t\tlocal flatdev="$(basename "$device")"\n'
 ' \t\t\t_xfs_metadump "$seqres.$flatdev.orebuild.md" "$device" \\\n'
 '-\t\t\t\t"$logdev" compress >> $seqres.full\n'
 '+\t\t\t\t"$logdev" "$rtdev" compress >> $seqres.full\n'
 ' \t\tfi\n'
 ' \tfi']

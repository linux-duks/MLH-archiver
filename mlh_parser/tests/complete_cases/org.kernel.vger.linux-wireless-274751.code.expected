['---\n'
 ' drivers/net/wireless/intel/iwlwifi/mld/tx.c | 11 +++++++++++\n'
 ' 1 file changed, 11 insertions(+)\n'
 '\n'
 'diff --git a/drivers/net/wireless/intel/iwlwifi/mld/tx.c '
 'b/drivers/net/wireless/intel/iwlwifi/mld/tx.c\n'
 'index fbb672f4d8c7..1d47254a4148 100644\n'
 '--- a/drivers/net/wireless/intel/iwlwifi/mld/tx.c\n'
 '+++ b/drivers/net/wireless/intel/iwlwifi/mld/tx.c\n'
 '@@ -846,6 +846,17 @@ static int iwl_mld_tx_tso_segment(struct iwl_mld *mld, '
 'struct sk_buff *skb,\n'
 ' \t */\n'
 ' \tnum_subframes = (max_tid_amsdu_len + pad) / (subf_len + pad);\n'
 ' \n'
 '+\t/* If the AMSDU length limit is too small to fit even a single\n'
 '+\t * subframe (e.g. max_tid_amsdu_len is the sentinel value 1 set by\n'
 '+\t * the TLC notification when AMSDU is disabled for this TID), fall\n'
 '+\t * back to non-AMSDU TSO segmentation. Without this guard,\n'
 '+\t * num_subframes=0 causes gso_size=0 in iwl_tx_tso_segment(),\n'
 '+\t * which makes skb_gso_segment() produce tens of thousands of\n'
 '+\t * 1-byte segments, overloading the TX ring and completion path.\n'
 '+\t */\n'
 '+\tif (!num_subframes)\n'
 '+\t\treturn iwl_tx_tso_segment(skb, 1, netdev_flags, mpdus_skbs);\n'
 '+\n'
 ' \tif (sta->max_amsdu_subframes &&\n'
 ' \t    num_subframes > sta->max_amsdu_subframes)\n'
 ' \t\tnum_subframes = sta->max_amsdu_subframes;\n'
 '-- \n'
 '2.52.0']
